{
    "description": "Multi-overload resolution: disambiguation by arg arity (0/1/2/3+) and arg types, ambiguous-without-argTypes error, no-matching-overload miss, selected-overload-first ordering, and overload count. Provider-neutral; see README.md.",
    "map": {
        "schema_version": 5,
        "app": "com.example.app",
        "version": "1.0.0",
        "version_code": 100,
        "classes": {
            "com.example.app.Overloaded": {
                "obfuscated": "aaaa",
                "methods": {
                    "f": [
                        {
                            "obfuscated": "a",
                            "signature": "()V"
                        },
                        {
                            "obfuscated": "b",
                            "signature": "(Landroid/os/Bundle;)V"
                        },
                        {
                            "obfuscated": "c",
                            "signature": "(Landroid/os/Bundle;Ljava/lang/String;)V"
                        },
                        {
                            "obfuscated": "d",
                            "signature": "(Landroid/os/Bundle;Ljava/lang/String;Lbbbb;)V"
                        },
                        {
                            "obfuscated": "e",
                            "signature": "(IJ)V"
                        }
                    ],
                    "g": [
                        {
                            "obfuscated": "p",
                            "signature": "(Ljava/lang/String;)V"
                        },
                        {
                            "obfuscated": "q",
                            "signature": "(Ljava/lang/CharSequence;)V"
                        }
                    ]
                }
            },
            "com.example.app.Callback": {
                "obfuscated": "bbbb",
                "kind": "interface"
            }
        }
    },
    "cases": [
        {
            "name": "ambiguous: 5 overloads, no argTypes",
            "kind": "method",
            "class": "com.example.app.Overloaded",
            "method": "f",
            "expectError": "AmbiguousOverload"
        },
        {
            "name": "disambiguate 0-arg overload",
            "kind": "method",
            "class": "com.example.app.Overloaded",
            "method": "f",
            "argTypes": [],
            "expectObf": "a",
            "expectSignature": "()V"
        },
        {
            "name": "disambiguate 1-arg overload",
            "kind": "method",
            "class": "com.example.app.Overloaded",
            "method": "f",
            "argTypes": ["android.os.Bundle"],
            "expectObf": "b"
        },
        {
            "name": "disambiguate 2-arg overload",
            "kind": "method",
            "class": "com.example.app.Overloaded",
            "method": "f",
            "argTypes": ["android.os.Bundle", "java.lang.String"],
            "expectObf": "c"
        },
        {
            "name": "disambiguate 3-arg overload with a translated real type",
            "kind": "method",
            "class": "com.example.app.Overloaded",
            "method": "f",
            "argTypes": ["android.os.Bundle", "java.lang.String", "com.example.app.Callback"],
            "expectObf": "d",
            "expectSignature": "(Landroid/os/Bundle;Ljava/lang/String;Lbbbb;)V"
        },
        {
            "name": "disambiguate by primitive arg types (int, long)",
            "kind": "method",
            "class": "com.example.app.Overloaded",
            "method": "f",
            "argTypes": ["int", "long"],
            "expectObf": "e"
        },
        {
            "name": "selected overload is placed first in allOverloads",
            "kind": "method",
            "class": "com.example.app.Overloaded",
            "method": "f",
            "argTypes": ["android.os.Bundle"],
            "expectObf": "b",
            "expectOverloadCount": 5
        },
        {
            "name": "no overload matches arg arity",
            "kind": "method",
            "class": "com.example.app.Overloaded",
            "method": "f",
            "argTypes": ["android.os.Bundle", "java.lang.String", "java.lang.String", "java.lang.String"],
            "expectError": "Resolve"
        },
        {
            "name": "no overload matches arg type (right arity, unmapped arg type -> UnknownArgType)",
            "kind": "method",
            "class": "com.example.app.Overloaded",
            "method": "g",
            "argTypes": ["java.lang.Integer"],
            "expectError": "UnknownArgType"
        },
        {
            "name": "exact-type match is not widened (String vs CharSequence)",
            "kind": "method",
            "class": "com.example.app.Overloaded",
            "method": "g",
            "argTypes": ["java.lang.CharSequence"],
            "expectObf": "q"
        }
    ]
}
