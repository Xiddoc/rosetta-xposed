{
    "description": "Error-taxonomy parity cases that pin behaviour the two resolvers must agree on: (1) parseSignatureArgs rejects an unknown descriptor char (e.g. 'Q') as a malformed-input IllegalArgument; (2) overload disambiguation against an unmapped class-name arg type raises the DISTINCT UnknownArgType error (a Resolve subtype) rather than the generic no-overload-matches Resolve, while a legitimate no-match still raises the generic Resolve. Provider-neutral; see README.md.",
    "map": {
        "schema_version": 2,
        "app": "com.example.app",
        "version": "1.0.0",
        "version_code": 100,
        "classes": {
            "com.example.app.Sink": {
                "obfuscated": "aaaa",
                "methods": {
                    "h": [
                        {
                            "obfuscated": "a",
                            "signature": "(Landroid/os/Bundle;Lbbbb;)V"
                        },
                        {
                            "obfuscated": "b",
                            "signature": "(Landroid/os/Bundle;Ljava/lang/String;Lbbbb;)V"
                        }
                    ]
                }
            },
            "com.example.app.Callback": {
                "obfuscated": "bbbb",
                "kind": "class"
            }
        }
    },
    "cases": [
        {
            "name": "parseSignatureArgs rejects unknown descriptor char (Q)",
            "kind": "parseSignatureArgs",
            "signature": "(Q)V",
            "expectError": "IllegalArgument"
        },
        {
            "name": "unmapped class-name arg type raises the distinct UnknownArgType error",
            "kind": "method",
            "class": "com.example.app.Sink",
            "method": "h",
            "argTypes": ["android.os.Bundle", "com.example.app.NotInMap"],
            "expectError": "UnknownArgType"
        },
        {
            "name": "all arg types known but no overload matches raises the generic Resolve error",
            "kind": "method",
            "class": "com.example.app.Sink",
            "method": "h",
            "argTypes": ["com.example.app.Callback"],
            "expectError": "Resolve"
        }
    ]
}
