                                "signature": ""
                            }
                        }
                    }
                }
            },
            "expectError": "MapValidation"
        },
        {
            "name": "empty field type is rejected (minLength:1)",
            "kind": "validate",
            "inputMap": {
                "schema_version": 3,
                "app": "com.example.app",
                "version": "1.0.0",
                "version_code": 100,
                "classes": {
                    "com.example.app.Foo": {
                        "obfuscated": "aaaa",
                        "fields": {
                            "baz": {
                                "obfuscated": "f",
                                "type": ""
                            }
                        }
                    }
                }
            },
            "expectError": "MapValidation"
        },
        {
            "name": "a negative version_code is rejected (lower-bound, nonnegative)",
            "kind": "validate",
            "inputMap": {
                "schema_version": 3,
                "app": "com.example.app",
                "version": "1.0.0",
                "version_code": -1,
                "classes": {
                    "com.example.app.Foo": {
                        "obfuscated": "aaaa"
                    }
                }
            },
            "expectError": "MapValidation"
        },
        {
            "name": "a reserved constructor class key is rejected (prototype-pollution guard)",
            "kind": "validate",
            "inputMap": {
                "schema_version": 3,
                "app": "com.example.app",
                "version": "1.0.0",
                "version_code": 100,
                "classes": {
                    "constructor": {
                        "obfuscated": "aaaa"
                    }
                }
            },
            "expectError": "MapValidation"
        },
        {
            "name": "a reserved prototype class key is rejected (prototype-pollution guard)",
            "kind": "validate",
            "inputMap": {
                "schema_version": 3,
                "app": "com.example.app",
                "version": "1.0.0",
                "version_code": 100,
