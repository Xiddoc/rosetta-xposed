                    }
                }
            },
            "expectError": "MapValidation"
        },
        {
            "name": "empty method signature is rejected (minLength:1)",
            "kind": "validate",
            "inputMap": {
                "schema_version": 3,
                "app": "com.example.app",
                "version": "1.0.0",
                "version_code": 100,
                "classes": {
                    "com.example.app.Foo": {
                        "obfuscated": "aaaa",
                        "methods": {
                            "bar": {
