{
    "description": "translateType semantics: a mapped real class name becomes its obfuscated short name; anything else (framework class, primitive name, unknown class) passes through unchanged. translateType operates on bare type names only (no array/descriptor wrappers). Provider-neutral; see README.md.",
    "map": {
        "schema_version": 4,
        "app": "com.example.app",
        "version": "1.0.0",
        "version_code": 100,
        "classes": {
            "com.example.app.Service": {
                "obfuscated": "aaaa"
            },
            "com.example.app.Outer$Inner": {
                "obfuscated": "bbbb"
            },
            "IShort": {
                "obfuscated": "cccc"
            }
        }
    },
    "cases": [
        {
            "name": "mapped class translates to obf",
            "kind": "translateType",
            "type": "com.example.app.Service",
            "expectResult": "aaaa"
        },
        {
            "name": "mapped inner class translates to obf",
            "kind": "translateType",
            "type": "com.example.app.Outer$Inner",
            "expectResult": "bbbb"
        },
        {
            "name": "mapped short name translates to obf",
            "kind": "translateType",
            "type": "IShort",
            "expectResult": "cccc"
        },
        {
            "name": "unmapped framework class passes through",
            "kind": "translateType",
            "type": "android.os.Bundle",
            "expectResult": "android.os.Bundle"
        },
        {
            "name": "primitive name passes through (not a class)",
            "kind": "translateType",
            "type": "int",
            "expectResult": "int"
        },
        {
            "name": "unknown class passes through unchanged",
            "kind": "translateType",
            "type": "com.example.app.Unknown",
            "expectResult": "com.example.app.Unknown"
        }
    ]
}
